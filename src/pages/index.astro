---
import Layout from '@/layouts/Layout.astro'
import HomeJLD from '@/components/HomeJLD.astro'

import { useDato, StructuredText } from '@/lib/dato-cms'
import { AUTHOR_EMAIL, LINKS, AUTHOR_NAME, TOPICS, AUTHOR_COUNTRY } from '@/lib/constants'

import type { ArticleImageBlock, IndexPage } from '@/lib/types'

export const prerender = true

const { data, error } = await useDato<IndexPage>(/* GraphQL */ `
   {
      home {
         seo {
            title
            description
         }
         title(markdown: true)
         body {
            value
            blocks {
               __typename
               ... on ArticleImageRecord {
                  id
                  image {
                     width
                     height
                     alt
                     url(imgixParams: { fm: webp, auto: enhance, cs: srgb })
                  }
               }
            }
         }
      }
   }
`)

if (error) throw new Error(error)

const cms = data.home
---

<Layout title={cms.seo.title} description={cms.seo.description}>
   <HomeJLD
      slot="head-end"
      url={import.meta.env.SITE}
      name={AUTHOR_NAME}
      description={cms.seo.description}
      email={AUTHOR_EMAIL}
      addressCountry={AUTHOR_COUNTRY}
      sameAs={Object.values(LINKS)}
      knowsAbout={TOPICS}
   />

   <article class="g-prose g-article-wrapper" id="article">
      <div class="g-hero-title" set:html={cms.title} />

      {
         StructuredText(cms.body, {
            ArticleImageRecord: (b: ArticleImageBlock) => {
               return (
                  <img
                     id="img"
                     src={b.image.url}
                     width={b.image.width}
                     height={b.image.height}
                     alt={b.image.alt}
                     loading="lazy"
                     decoding="async"
                  />
               )
            },
            content: (html) => <Fragment set:html={html} />,
         })
      }
   </article>
</Layout>
