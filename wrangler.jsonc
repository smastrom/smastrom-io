{
   "name": "smastrom-io",
   "pages_build_output_dir": "./dist",
   "compatibility_flags": [
      "nodejs_compat",
      "disable_nodejs_process_v2"
   ],
   "compatibility_date": "2025-09-27",
   "env": {
      "production": {
         "vars": {
            "IS_PREVIEW": "false"
         }
      },
      "preview": {
         "vars": {
            "IS_PREVIEW": "true"
         }
      }
   },
   "observability": {
      "enabled": true
   }
}