---
import IconPayPal from '@/components/icons/paypal.svg'
import IconCoffee from '@/components/icons/coffee.svg'
import IconCrypto from '@/components/icons/crypto.svg'

import { useDato } from '@/lib/dato-cms'
import { DONATE_LINKS } from '@/lib/constants'

import type { MarketingContent } from '@/lib/types'

const { data, error: cmsErr } = await useDato<MarketingContent>(/* GraphQL */ `
   {
      marketingContent {
         donateSectionTitle
         donateSectionSubtitle(markdown: true)
      }
   }
`)

if (cmsErr) throw new Error(cmsErr)

const title = data.marketingContent.donateSectionTitle
const subtitle = data.marketingContent.donateSectionSubtitle

const DONATE_ICONS = {
   paypal: IconPayPal,
   coffee: IconCoffee,
   crypto: IconCrypto,
} as const
---

<section class="Section">
   <h2 class="G_Title_2">{title}</h2>
   <div class="G_Paragraphs" set:html={subtitle} />

   <div class="Donate_Groups">
      {
         Object.entries(DONATE_LINKS).map(([group, links]) => (
            <div class="Donate_Group">
               <span class="Donate_Group_Label">
                  {group === 'card' ? 'Cards, PayPal' : 'Crypto'}
               </span>
               <div class="Donate_Links">
                  {links.map((link) => {
                     const Icon = DONATE_ICONS[link.slug]
                     return (
                        <a
                           href={link.url}
                           target="_blank"
                           rel="noopener noreferrer"
                           class="Donate_Link"
                        >
                           <Icon /> {link.label}
                        </a>
                     )
                  })}
               </div>
            </div>
         ))
      }
   </div>
</section>

<style>
   .Section {
      width: 100%;
      display: flex;
      flex-direction: column;
   }

   .Donate_Groups {
      display: flex;
      column-gap: var(--s-6);
      row-gap: var(--s-3);
      margin-top: var(--s-2);
      flex-wrap: wrap;
   }

   .Donate_Group {
      display: flex;
      flex-direction: column;
      gap: var(--s-1);
   }

   .Donate_Group_Label {
      font-size: var(--f-0);
      font-weight: 600;
      color: var(--fg-2);
   }

   .Donate_Links {
      display: flex;
      gap: var(--s-1);
      flex-wrap: wrap;
   }

   .Donate_Link {
      display: inline-flex;
      align-items: center;
      gap: var(--s-05);
      padding: var(--s-07) var(--s-2);
      border-radius: var(--r-3);
      border: var(--b-1) solid var(--divider-light);
      background-color: var(--bg-alpha);
      color: var(--fg);
      font-size: var(--f-1);
      font-weight: 500;
      text-decoration: none;
      transition:
         border-color var(--easing),
         color var(--easing);

      & :global(svg) {
         width: 1.125rem;
         height: 1.125rem;
         color: var(--accent);
         transition: color var(--easing);
      }

      @media (hover: hover) {
         &:hover {
            border-color: var(--accent);
            color: var(--accent);
         }
      }
   }
</style>
