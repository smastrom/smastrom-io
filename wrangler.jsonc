{
   "main": "dist/_worker.js/index.js",
   "name": "smastrom-io",
   "compatibility_date": "2025-03-25",
   "compatibility_flags": [
     "nodejs_compat",
     "global_fetch_strictly_public"
   ],
   "assets": {
     "binding": "ASSETS",
     "directory": "./dist"
   },
   "vars": {
      "IS_PREVIEW": "true"
   },
   "env": {
      "preview": {
         "vars": {
            "IS_PREVIEW": "true"
         },
      },
   },
   "observability": {
      "enabled": true
   },
}
