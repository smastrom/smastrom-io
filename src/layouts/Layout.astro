---
import Head from '@/components/Head.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import Background from '@/components/Background.astro'
import JsonLd from '@/components/JsonLd.astro'

import { useDato } from '@/lib/dato-cms'
import { AUTHOR_NAME, AUTHOR_EMAIL, SITE_URL, LINKS, TOPICS } from '@/lib/constants'

import type { CmsLayout } from '@/lib/types'

import '@/styles/reset.css'
import '@/styles/colors.css'
import '@/styles/layout.css'
import '@/styles/typography.css'
import '@/styles/hamburger.css'
import '@/styles/classes.css'
import '@/styles/smastrom-variables.css'

const { data, error } = await useDato<CmsLayout>(/* GraphQL */ `
   {
      _site {
         globalSeo {
            fallbackSeo {
               title
               description
            }
         }
      }
      layout {
         footerText(markdown: true)
      }
   }
`)

if (error) throw new Error(error)

const { fallbackSeo } = data._site.globalSeo

const { title = fallbackSeo.title, description = fallbackSeo.description } = Astro.props as {
   title: string
   description: string
}

const sharedJsonLd = {
   '@context': 'https://schema.org',
   '@graph': [
      {
         '@type': 'Person',
         '@id': `${SITE_URL}/#person`,
         name: AUTHOR_NAME,
         givenName: 'Simone',
         jobTitle: 'Software Professional',
         url: SITE_URL,
         email: `mailto:${AUTHOR_EMAIL}`,
         knowsAbout: TOPICS,
         homeLocation: {
            '@type': 'Place',
            address: {
               '@type': 'PostalAddress',
               addressCountry: 'IT',
            },
         },
         sameAs: Object.values(LINKS),
      },
      {
         '@type': 'WebSite',
         '@id': `${SITE_URL}/#website`,
         url: SITE_URL,
         name: `${AUTHOR_NAME} - Web Developer`,
         publisher: { '@id': `${SITE_URL}/#person` },
      },
   ],
}
---

<!doctype html>
<!-- TODO: Revert to data-theme="auto" once Astro supports custom worker entry point (HTMLRewriter) -->
<html lang="en" dir="ltr" data-theme="dark" class="g-transitions">
   <Head {title} {description}>
      <JsonLd data={sharedJsonLd} />
      <slot name="head-end" />
   </Head>

   <body>
      <Background />
      <a href="#main" class="g-sr-only">Skip to main content</a>

      <Header />

      <div id="content">
         <main id="main">
            <slot />
         </main>

         <Footer content={data.layout.footerText} />
      </div>
   </body>
</html>
