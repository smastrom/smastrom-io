---
import IconStar from '@/components/icons/IconStar.astro'
import IconDownloads from '@/components/icons/IconDownloads.astro'
import IconDemo from '@/components/icons/demo.svg'
import IconGitHub from '@/components/icons/IconGitHub.astro'
import IconNpm from '@/components/icons/IconNpm.astro'

import NpmLogo from '@/components/icons/npm.svg'
import AppleLogo from '@/components/icons/apple.svg'

import { formatDownloadNumber, getExtLinkAttrs, stripEmoji } from '@/lib/utils'

import type { ProjectPackage } from '@/lib/types'

import '@/styles/tilt.css'

const { project: p } = Astro.props as { project: ProjectPackage }
---

<li class="Card">
   {Array.from({ length: 7 }).map(() => <div class="G_Tilt_Square" aria-hidden="true" />)}

   <section class="Card_Content G_Tilt_Content">
      <div>
         <div class="Header">
            {p.type === 'npm' && <NpmLogo class="Npm_Logo" aria-hidden="true" />}

            {p.type === 'mac' && <AppleLogo class="Apple_Logo" aria-hidden="true" />}

            <h2>{p.title}</h2>
         </div>
         <p class="Subtitle">{stripEmoji(p.description)}</p>
      </div>

      <div class="Footer">
         <div class="Stats">
            <div class="Icon_Box">
               <IconStar />
               {formatDownloadNumber(p.stargazers_count)}
               <span class="G_SR_Only">stars</span>
            </div>

            <div class="Icon_Box">
               <IconDownloads />
               {formatDownloadNumber(p.total_downloads)}
               <span class="G_SR_Only">downloads</span>
            </div>
         </div>

         <nav class="Right_Nav">
            {
               p.demo_url && (
                  <a {...getExtLinkAttrs(p.demo_url, 'View website')}>
                     <IconDemo />
                  </a>
               )
            }

            <a {...getExtLinkAttrs(p.github_url, 'View on GitHub')}>
               <IconGitHub />
            </a>

            {
               p.type === 'npm' && (
                  <a {...getExtLinkAttrs(p.npm_url, 'View on NPM')}>
                     <IconNpm />
                  </a>
               )
            }
         </nav>
      </div>
   </section>
</li>

<style>
   .Card {
      width: 100%;
      position: relative;
      height: 200px;
   }

   .Card_Content {
      padding: var(--s-3);
      border-radius: var(--r-3);
      box-shadow: 0 0 0 var(--b-1) var(--divider-light);
      user-select: none;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 100%;
      background-color: var(--bg-alpha);
      backdrop-filter: blur(10px);
      transition:
         transform 500ms linear,
         transform-origin 500ms linear,
         box-shadow var(--easing),
         background-color var(--easing);

      @media (hover: hover) {
         &:hover {
            box-shadow: 0 0 0 var(--b-1) var(--accent);
         }
      }

      @media (--tablet-to) {
         backdrop-filter: none;
      }

      @media (--mobile-to) {
         padding: var(--s-2);
      }

      .Header {
         display: flex;
         align-items: center;
         gap: var(--s-1);
         margin-bottom: var(--s-2);

         & h2 {
            font-size: var(--f-3);
            font-weight: 700;
            line-height: 1;

            @media (--tablet-to) {
               font-size: var(--f-2);
            }
         }

         & :global(svg.Npm_Logo) {
            width: 40px;
            height: auto;
            color: var(--accent);

            @media (--tablet-to) {
               width: 30px;
            }
         }

         & :global(svg.Apple_Logo) {
            width: 1rem;
            height: auto;
            color: var(--accent);
         }
      }

      & .Subtitle {
         font-size: var(--f-1);
         margin-bottom: var(--s-2);
      }

      & .Divider {
         width: 100%;
         height: var(--b-1);
         background-color: var(--divider-light);
         display: block;
         margin: var(--s-2) 0;
         transition: background-color var(--easing);
      }

      & .Footer {
         display: flex;
         align-items: center;
         justify-content: space-between;
         flex-wrap: wrap;
         gap: var(--s-3);
      }

      & .Stats {
         display: flex;
         align-items: center;
         gap: var(--s-4);

         @media (--tablet-to) {
            gap: var(--s-1);
         }
      }

      & .Icon_Box {
         display: flex;
         align-items: center;
         gap: var(--s-02);
         font-size: var(--f-09);
         font-weight: 500;
         transition: color var(--easing);

         & :global(svg) {
            width: var(--s-2);
            height: var(--s-2);
            color: var(--accent);
            transition: all var(--easing);
         }
      }

      .Right_Nav {
         display: flex;
         align-items: center;
         gap: var(--s-1);

         & a {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--s-05);
            border-radius: var(--r-2);
            height: 100%;
            border: var(--b-1) solid var(--divider);
            background-color: var(--bg-elv);
            cursor: pointer;
            transition:
               background-color var(--easing),
               border-color var(--easing);

            & :global(svg) {
               transition: color var(--easing);
               width: 1.125rem;
               height: 1.125rem;
            }

            @media (hover: hover) {
               &:hover {
                  & :global(svg) {
                     color: var(--accent);
                  }
               }
            }
         }
      }
   }
</style>
