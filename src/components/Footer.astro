---
import Logo from './Logo.astro'

const { content } = Astro.props as { content: string }
---

<footer class="Footer">
   <small set:html={content.replace('[YEAR]', String(new Date().getFullYear()))} />

   <Logo width="40" height="40" style={{ display: 'flex', marginBottom: 'var(--s-07)' }} />
</footer>

<style scoped>
   .Footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: var(--footer-space) auto 0 auto;
      width: var(--container-max);
      max-width: 100%;
      font-size: var(--f-4);

      & small {
         height: min-content;
      }

      @media (--tablet-to) {
         font-size: var(--f-2);
         align-items: flex-start;
         flex-direction: column-reverse;
      }

      & :global(span) {
         color: var(--color-accent);
      }

      & :global(a) {
         text-decoration: underline;
         text-underline-offset: var(--s-02);
         text-decoration-color: var(--color-fg-underline);
         transition: text-decoration-color var(--ease-fast);
      }

      @media (hover: hover) {
         & :global(a):hover {
            text-decoration-color: var(--color-fg);
         }
      }
   }
</style>
