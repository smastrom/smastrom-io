---
import IconPayPal from '@/components/icons/paypal.svg'
import IconCoffee from '@/components/icons/coffee.svg'
import IconCrypto from '@/components/icons/crypto.svg'

import { useDato } from '@/lib/dato-cms'
import { DONATE_LINKS } from '@/lib/constants'

import type { MarketingContent } from '@/lib/types'

const { data, error: cmsErr } = await useDato<MarketingContent>(/* GraphQL */ `
   {
      marketingContent {
         donateSectionTitle
         donateSectionSubtitle(markdown: true)
      }
   }
`)

if (cmsErr) throw new Error(cmsErr)

const title = data.marketingContent.donateSectionTitle
const subtitle = data.marketingContent.donateSectionSubtitle

const DONATE_ICONS = {
   paypal: IconPayPal,
   coffee: IconCoffee,
   crypto: IconCrypto,
} as const
---

<section class="DonateSection">
   <h2 class="g-title-2">{title}</h2>
   <div class="g-paragraphs" set:html={subtitle} />

   <div class="DonateSection-groups">
      {
         Object.entries(DONATE_LINKS).map(([group, links]) => (
            <div class="DonateSection-group">
               <span class="DonateSection-label">
                  {group === 'card' ? 'Cards, PayPal' : 'Crypto'}
               </span>
               <div class="DonateSection-links">
                  {links.map((link) => {
                     const Icon = DONATE_ICONS[link.slug]
                     return (
                        <a
                           href={link.url}
                           target="_blank"
                           rel="noopener noreferrer"
                           class="DonateSection-link"
                        >
                           <Icon /> {link.label}
                        </a>
                     )
                  })}
               </div>
            </div>
         ))
      }
   </div>
</section>

<style>
   .DonateSection {
      width: 100%;
      display: flex;
      flex-direction: column;
   }

   .DonateSection-groups {
      display: flex;
      column-gap: var(--s-6);
      row-gap: var(--s-3);
      margin-top: var(--s-2);
      flex-wrap: wrap;
   }

   .DonateSection-group {
      display: flex;
      flex-direction: column;
      gap: var(--s-1);
   }

   .DonateSection-label {
      font-size: var(--f-0);
      font-weight: 600;
      color: var(--fg-2);
   }

   .DonateSection-links {
      display: flex;
      gap: var(--s-1);
      flex-wrap: wrap;
   }

   .DonateSection-link {
      display: inline-flex;
      align-items: center;
      gap: var(--s-05);
      padding: var(--s-07) var(--s-2);
      border-radius: var(--r-3);
      border: var(--b-1) solid var(--color-border-muted);
      background-color: var(--color-bg-translucent);
      color: var(--color-fg);
      font-size: var(--f-1);
      font-weight: 500;
      text-decoration: none;
      transition:
         border-color var(--ease-fast),
         color var(--ease-fast);

      & :global(svg) {
         width: 1.125rem;
         height: 1.125rem;
         color: var(--color-accent);
         transition: color var(--ease-fast);
      }

      @media (hover: hover) {
         &:hover {
            border-color: var(--color-accent);
            color: var(--color-accent);
         }
      }
   }
</style>
