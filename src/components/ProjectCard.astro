---
import IconStar from '@/components/icons/IconStar.astro'
import IconDownloads from '@/components/icons/IconDownloads.astro'
import IconGlobe from '@/components/icons/IconGlobe.astro'
import IconGitHub from '@/components/icons/IconGitHub.astro'
import IconNpm from '@/components/icons/IconNpm.astro'

import { formatDownloadNumber, getExtLinkAttrs, stripEmoji } from '@/lib/utils'

import type { ProjectPackage } from '@/lib/types'

import '@/styles/tilt.css'

const { project: p } = Astro.props as { project: ProjectPackage }
---

<li class="Card">
   {Array.from({ length: 7 }).map(() => <div class="G_Tilt_Square" aria-hidden="true" />)}

   <section class="Card_Content G_Tilt_Content">
      <div>
         <div class="Header">
            {
               p.type === 'npm' && (
                  <svg
                     xmlns="http://www.w3.org/2000/svg"
                     width="100%"
                     height="100%"
                     viewBox="0 0 18 7"
                     class="Npm_Logo"
                     aria-hidden="true"
                  >
                     <path
                        class="Npm_Logo_Path"
                        d="M0,0h18v6H9v1H5V6H0V0z M1,5h2V2h1v3h1V1H1V5z M6,1v5h2V5h2V1H6z M8,2h1v2H8V2z M11,1v4h2V2h1v3h1V2h1v3h1V1H11z"
                     />
                     <g class="Npm_Logo_Inner">
                        <polygon points="1,5 3,5 3,2 4,2 4,5 5,5 5,1 1,1 " />
                        <path d="M6,1v5h2V5h2V1H6z M9,4H8V2h1V4z" />
                        <polygon points="11,1 11,5 13,5 13,2 14,2 14,5 15,5 15,2 16,2 16,5 17,5 17,1 " />
                     </g>
                  </svg>
               )
            }

            {
               p.type === 'mac' && (
                  <svg
                     xmlns="http://www.w3.org/2000/svg"
                     class="Apple_Logo"
                     xml:space="preserve"
                     viewBox="0 0 814 1000"
                     width="100%"
                     height="100%"
                     fill="currentColor"
                  >
                     <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z" />
                  </svg>
               )
            }

            <h2>{p.title}</h2>
         </div>
         <p class="Subtitle">{stripEmoji(p.description)}</p>
      </div>

      <div class="Footer">
         <div class="Stats">
            <div class="Icon_Box">
               <IconStar />
               {formatDownloadNumber(p.stargazers_count)}
               <span class="G_SR_Only">stars</span>
            </div>

            <div class="Icon_Box">
               <IconDownloads />
               {formatDownloadNumber(p.total_downloads)}
               <span class="G_SR_Only">downloads</span>
            </div>
         </div>

         <nav class="Right_Nav">
            {
               p.demo_url && (
                  <a {...getExtLinkAttrs(p.demo_url, 'View website')}>
                     <IconGlobe />
                  </a>
               )
            }

            <a {...getExtLinkAttrs(p.github_url, 'View on GitHub')}>
               <IconGitHub />
            </a>

            {
               p.type === 'npm' && (
                  <a {...getExtLinkAttrs(p.npm_url, 'View on NPM')}>
                     <IconNpm />
                  </a>
               )
            }
         </nav>
      </div>
   </section>
</li>

<style>
   .Card {
      width: 100%;
      position: relative;
      height: 200px;
   }

   html[data-theme='light'] .Card_Content {
      background: transparent;
      box-shadow: 0 0 0 2px var(--divider-light);
      backdrop-filter: blur(var(--s-05));

      @media (hover: hover) {
         &:hover {
            box-shadow: 0 0 0 2px var(--accent);
         }
      }
   }

   .Card_Content {
      padding: var(--s-3);
      border-radius: var(--r-3);
      box-shadow: 0 0 0 var(--b-1) var(--divider);
      user-select: none;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 100%;
      background-color: var(--bg-alpha);
      backdrop-filter: blur(10px);
      transition:
         transform 500ms linear,
         transform-origin 500ms linear,
         box-shadow var(--easing),
         background-color var(--easing);

      @media (hover: hover) {
         &:hover {
            box-shadow: 0 0 0 var(--b-1) var(--accent);
         }
      }

      @media (--tablet-to) {
         backdrop-filter: none;
      }

      @media (--mobile-to) {
         padding: var(--s-2);
      }

      .Header {
         display: flex;
         align-items: center;
         gap: var(--s-1);
         margin-bottom: var(--s-2);

         & h2 {
            font-size: var(--f-3);
            font-weight: 700;
            line-height: 1;

            @media (--tablet-to) {
               font-size: var(--f-2);
            }
         }

         & .Npm_Logo {
            width: 40px;
            height: auto;
            color: var(--accent);

            @media (--tablet-to) {
               width: 30px;
            }

            & .Npm_Logo_Inner {
               display: none;
            }

            & .Npm_Logo_Path {
               fill: var(--accent);
            }
         }

         & .Apple_Logo {
            width: 1rem;
            height: auto;
            color: var(--accent);
         }
      }

      & .Subtitle {
         font-size: var(--f-1);
         margin-bottom: var(--s-2);
      }

      & .Divider {
         width: 100%;
         height: var(--b-1);
         background-color: var(--divider-light);
         display: block;
         margin: var(--s-2) 0;
         transition: background-color var(--easing);
      }

      & .Footer {
         display: flex;
         align-items: center;
         justify-content: space-between;
         flex-wrap: wrap;
         gap: var(--s-3);
      }

      & .Stats {
         display: flex;
         align-items: center;
         gap: var(--s-4);

         @media (--tablet-to) {
            gap: var(--s-1);
         }
      }

      & .Icon_Box {
         display: flex;
         align-items: center;
         gap: var(--s-02);
         font-size: var(--f-09);
         font-weight: 500;
         transition: color var(--easing);

         & :global(svg) {
            width: var(--s-2);
            height: var(--s-2);
            color: var(--accent);
            transition: all var(--easing);
         }
      }

      .Right_Nav {
         display: flex;
         align-items: center;
         gap: var(--s-1);

         & a {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--s-05);
            border-radius: var(--r-2);
            height: 100%;
            border: var(--b-1) solid var(--divider);
            background-color: var(--bg-elv);
            cursor: pointer;
            transition:
               background-color var(--easing),
               border-color var(--easing);

            & :global(svg) {
               transition: color var(--easing);
               width: 1.125rem;
               height: 1.125rem;
            }

            @media (hover: hover) {
               &:hover {
                  & :global(svg) {
                     color: var(--accent);
                  }
               }
            }
         }
      }
   }
</style>
